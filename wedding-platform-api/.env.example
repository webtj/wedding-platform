# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wedding_platform?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (min 32 chars)
JWT_ACCESS_SECRET=your-access-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# URLs
API_PUBLIC_BASE_URL=http://localhost:4000
WEB_PUBLIC_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Settings Encryption (min 32 chars)
SETTINGS_ENCRYPTION_SECRET=your-encryption-secret-here-min-32-chars

# AI Providers (optional, configure in admin settings)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# WeChat Mini Program (optional)
# WECHAT_MINI_APP_ID=
# WECHAT_MINI_APP_SECRET=

# Douyin Mini Program (optional)
# DOUYIN_MINI_APP_ID=
# DOUYIN_MINI_APP_SECRET=
