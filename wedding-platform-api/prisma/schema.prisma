generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  disabled
}

enum UserStatus {
  active
  disabled
}

enum MemberStatus {
  active
  disabled
}

enum AuthProvider {
  password
  phone
}

enum PlatformAdminLevel {
  super // 超级管理员：一切权限，不可删除
  admin // 平台管理员：可管理租户、套餐等
}

model PlatformAdmin {
  id        String             @id @default(cuid())
  userId    String             @unique
  level     PlatformAdminLevel @default(admin)
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_admins")
}

enum RoleScope {
  tenant
}

enum MenuScope {
  platform // 平台菜单（只有超管看到）
  tenant // 租户菜单（按角色分配）
}

enum LeadStatus {
  new
  contacted
  quoted
  negotiating
  won
  lost
}

enum LeadSourceChannel {
  wechat
  xiaohongshu
  douyin
  referral
  other
}

enum ProjectStatus {
  pending
  active
  completed
}

enum ProjectMemberRole {
  planner
}

enum TaskStatus {
  todo
  in_progress
  done
  closed
}

enum AssetStatus {
  uploading
  ready
  archived
  deleted
}

enum NotificationType {
  task
  task_reminder
  asset
  ai
  system
  contract_update
  system_alert
}

enum NotificationChannel {
  in_app
  sms
  email
}

enum AiJobStatus {
  queued
  succeeded
  failed
}

enum AiJobType {
  vows
  speech
  social_copy
  planner_marketing
}

enum AiGenerationType {
  text2img
  img2img
  edit
  upscale
}

enum AiGenerationStatus {
  pending
  processing
  completed
  failed
}

enum ArchivePackageStatus {
  queued
  processing
  ready
  failed
  expired
}

enum ArchivePackageType {
  full_project
  assets_only
  case_draft
}

enum RetentionReminderStatus {
  pending
  sent
  dismissed
}

enum PromptCategoryType {
  image_design
  copywriting
  general
}

enum ProjectStageStatus {
  pending
  active
  done
  skipped
}

enum TimelineItemStatus {
  pending
  ready
  in_progress
  done
  canceled
}

enum ContractStatus {
  pending_sign
  signed
  voided
}

enum MaterialStatus {
  available
  missing
}

enum AiGenerationJobStatus {
  queued
  processing
  completed
  failed
}

enum MessageRole {
  user
  assistant
  system
}

enum ReferenceAssetRole {
  style
  subject
  pet
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  description String       @default("")
  address     String?
  status      TenantStatus @default(active)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  members   TenantMember[]
  roles     Role[]
  menuItems MenuItem[]

  leads         Lead[]
  projects      Project[]
  contracts     Contract[]
  notifications Notification[]
  auditLogs     AuditLog[]

  archivePackages    ArchivePackage[]
  retentionPolicies  AssetRetentionPolicy[]
  retentionReminders RetentionReminder[]

  processTemplates   ProcessTemplate[]
  materialCategories MaterialCategory[]
  materialTypes      MaterialType[]
  materials          Material[]
  quickPromptCategories QuickPromptCategory[]
  quickPrompts       QuickPrompt[]
  aiGenerations      AiGeneration[]
  aiConversations    AiConversation[]
  scenes             Scene[]

  aiUsageRecords        AiUsageRecord[]
  aiGenerationFeedbacks AiGenerationFeedback[]
  aiReferenceAssets     AiReferenceAsset[]
  aiTextGenerations     AiTextGeneration[]
  subtasks              Subtask[]

  @@map("tenants")
}

model User {
  id                 String     @id @default(cuid())
  displayName        String
  status             UserStatus @default(active)
  tokenVersion       Int        @default(0)
  lastActiveTenantId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  authAccounts    AuthAccount[]
  tenantMembers   TenantMember[]
  refreshSessions RefreshSession[]
  platformAdmin   PlatformAdmin?

  projectMembers        ProjectMember[]
  assignedTasks         Task[]                 @relation("TaskAssignedUser")
  notifications         Notification[]
  auditLogs             AuditLog[]
  createdLeads          Lead[]                 @relation("LeadCreatedBy")
  createdFollowups      LeadFollowup[]         @relation("FollowupCreatedBy")
  uploadedAssets        Asset[]                @relation("AssetUploadedBy")
  aiJobs                AiJob[]                @relation("AiJobRequestedBy")
  aiGenerations         AiGeneration[]         @relation("AiGenerationsByUser")
  aiConversations       AiConversation[]
  aiUsageRecords        AiUsageRecord[]
  aiGenerationFeedbacks AiGenerationFeedback[]
  aiReferenceAssets     AiReferenceAsset[]
  aiTextGenerations     AiTextGeneration[]

  notificationPreference UserNotificationPreference?

  plannedProjects        Project[]        @relation("ProjectPlanner")
  createdArchivePackages ArchivePackage[] @relation("ArchivePackageCreatedBy")

  @@map("users")
}

model AuthAccount {
  id           String       @id @default(cuid())
  userId       String
  provider     AuthProvider
  identifier   String
  passwordHash String?
  verifiedAt   DateTime?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, identifier])
  @@index([userId])
  @@map("auth_accounts")
}

model TenantMember {
  id          String       @id @default(cuid())
  tenantId    String
  userId      String
  displayName String
  status      MemberStatus @default(active)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles  MemberRole[]

  projectMembers        ProjectMember[]
  assignedTasks         TaskAssignee[]
  templateTaskAssignees ProcessTemplateTaskAssignee[]

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

model Role {
  id              String    @id @default(cuid())
  tenantId        String?
  scope           RoleScope
  code            String
  name            String
  description     String?
  isBuiltIn       Boolean   @default(false)
  permissionCodes String[]  @default([])  // 单一权限来源：菜单勾选后自动派发；内置角色 seed 一次性写入
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members       MemberRole[]
  menus         RoleMenuItem[]
  templateTasks ProcessTemplateTask[]
  projectTasks  Task[]

  @@unique([scope, tenantId, code])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  group       String
  description String?
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model MemberRole {
  memberId String
  roleId   String

  member TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([memberId, roleId])
  @@map("member_roles")
}

model MenuItem {
  id              String    @id @default(cuid())
  tenantId        String?
  scope           MenuScope @default(tenant)
  parentId        String?
  label           String
  href            String?
  icon            String?
  sortOrder       Int       @default(0)
  visible         Boolean   @default(true)
  permissionCodes String[]  @default([])  // 1:N — 勾选此菜单时自动给角色授予这些权限
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   MenuItem?      @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[]     @relation("MenuTree")
  roles    RoleMenuItem[]

  @@index([tenantId])
  @@index([parentId])
  @@map("menu_items")
}

model RoleMenuItem {
  roleId     String
  menuItemId String

  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([roleId, menuItemId])
  @@map("role_menu_items")
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_sessions")
}

model Lead {
  id                 String            @id @default(cuid())
  tenantId           String
  leadNo             String            @unique
  name               String
  phone              String?
  email              String?
  sourceChannel      LeadSourceChannel @default(other)
  status             LeadStatus        @default(new)
  consultationTime   DateTime?
  weddingDate        DateTime?
  budgetCents        Int?
  note               String?
  lostReason         String?
  convertedAt        DateTime?
  convertedProjectId String?           @unique
  contractId         String?           @unique
  createdByUserId    String
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("LeadCreatedBy", fields: [createdByUserId], references: [id])
  followups        LeadFollowup[]
  convertedProject Project?       @relation("LeadConvertedProject", fields: [convertedProjectId], references: [id])
  contract         Contract?      @relation("LeadContract", fields: [contractId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, weddingDate])
  @@index([tenantId, sourceChannel])
  @@map("leads")
}

model LeadFollowup {
  id              String    @id @default(cuid())
  leadId          String
  tenantId        String
  content         String
  nextFollowUpAt  DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation("FollowupCreatedBy", fields: [createdByUserId], references: [id])

  @@index([tenantId, leadId])
  @@map("lead_followups")
}

model Project {
  id                  String        @id @default(cuid())
  tenantId            String
  leadId              String?       @unique
  projectNo           String        @unique
  brideName           String
  groomName           String
  weddingDate         DateTime
  ceremonyType        String?
  venue               String?
  guestCount          Int?
  guestCountFinal     Int?
  colorTheme          String?
  style               String?
  specialRequirements String?
  plannerId           String?
  appliedTemplateId   String?
  status              ProjectStatus @default(pending)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planner           User?                 @relation("ProjectPlanner", fields: [plannerId], references: [id], onDelete: SetNull)
  convertedFromLead Lead?                 @relation("LeadConvertedProject")
  members           ProjectMember[]
  tasks             Task[]
  stages            ProjectStage[]
  contracts         Contract[]
  assets            Asset[]
  timelineItems     WeddingTimelineItem[]
  aiJobs            AiJob[]
  aiOutputs         AiOutput[]
  aiGenerations     AiGeneration[]
  aiConversations   AiConversation[]
  scenes            Scene[]
  aiReferenceAssets AiReferenceAsset[]
  aiTextGenerations AiTextGeneration[]

  completedAt        DateTime?
  archivedAt         DateTime?
  archiveNote        String?
  retentionPolicy    AssetRetentionPolicy?
  archivePackages    ArchivePackage[]
  retentionReminders RetentionReminder[]

  @@index([tenantId, status])
  @@index([tenantId, weddingDate])
  @@map("projects")
}

model Scene {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  name      String
  width     Float
  height    Float
  unit      String   @default("meter")
  sceneData Json
  thumbnail String?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("scenes")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  tenantId  String
  userId    String
  memberId  String?
  role      String   @default("planner")
  createdAt DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  member  TenantMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId, role])
  @@index([tenantId, userId])
  @@map("project_members")
}

model Task {
  id             String     @id @default(cuid())
  tenantId       String
  projectId      String
  stageId        String?
  title          String
  description    String?
  status         TaskStatus @default(todo)
  assigneeType   String     @default("planner")
  assignedRoleId String?
  assignedUserId String?
  dueDate        DateTime?
  priority       Int        @default(2)
  sortOrder      Int        @default(0)
  isBlocked      Boolean    @default(false)
  blockReason    String?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage         ProjectStage?  @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assignedUser  User?          @relation("TaskAssignedUser", fields: [assignedUserId], references: [id])
  assignedRole  Role?          @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)
  assignees     TaskAssignee[]
  taskMaterials TaskMaterial[]
  subtasks      Subtask[]

  @@index([tenantId, projectId, status])
  @@index([tenantId, projectId, stageId, sortOrder])
  @@map("tasks")
}

model ProcessTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages ProcessTemplateStage[]

  @@index([tenantId])
  @@map("process_templates")
}

model ProcessTemplateStage {
  id          String   @id @default(cuid())
  templateId  String
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template ProcessTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks    ProcessTemplateTask[]

  @@index([templateId, sortOrder])
  @@map("process_template_stages")
}

model ProcessTemplateTask {
  id             String   @id @default(cuid())
  stageId        String
  title          String
  description    String?
  assigneeType   String   @default("planner")
  assignedRoleId String?
  priority       Int      @default(2)
  offsetDays     Int      @default(0)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stage          ProcessTemplateStage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  assignedRole   Role?                          @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)
  assignees      ProcessTemplateTaskAssignee[]
  checklistItems ProcessTemplateChecklistItem[]

  @@index([stageId, sortOrder])
  @@map("process_template_tasks")
}

model ProcessTemplateChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  task ProcessTemplateTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
  @@map("process_template_checklist_items")
}

model ProcessTemplateTaskAssignee {
  id             String @id @default(cuid())
  templateTaskId String
  memberId       String

  templateTask ProcessTemplateTask @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)
  member       TenantMember        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([templateTaskId, memberId])
  @@map("process_template_task_assignees")
}

model Asset {
  id               String      @id @default(cuid())
  tenantId         String
  projectId        String
  filename         String
  contentType      String
  sizeBytes        Int
  category         String?
  objectKey        String
  status           AssetStatus @default(uploading)
  uploadedByUserId String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User           @relation("AssetUploadedBy", fields: [uploadedByUserId], references: [id])
  versions   AssetVersion[]

  expiresAt           DateTime?
  archivePackageItems ArchivePackageItem[]
  retentionReminders  RetentionReminder[]

  @@index([tenantId, projectId, status])
  @@map("assets")
}

model AssetVersion {
  id        String   @id @default(cuid())
  assetId   String
  version   Int
  objectKey String
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@map("asset_versions")
}

model WeddingTimelineItem {
  id                    String             @id @default(cuid())
  tenantId              String
  projectId             String
  startTime             DateTime
  title                 String
  description           String?
  owner                 String?
  location              String?
  status                TimelineItemStatus @default(pending)
  sortOrder             Int                @default(0)
  reminderMinutesBefore Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId, sortOrder])
  @@index([tenantId, projectId, startTime])
  @@map("wedding_timeline_items")
}

model Notification {
  id        String              @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(in_app)
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, channel, readAt])
  @@map("notifications")
}

model UserNotificationPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  phone       String?
  email       String?
  preferInApp Boolean  @default(true)
  preferSms   Boolean  @default(false)
  preferEmail Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, entity, entityId])
  @@map("audit_logs")
}

model AiJob {
  id                String      @id @default(cuid())
  tenantId          String
  projectId         String
  type              AiJobType
  prompt            String
  status            AiJobStatus @default(queued)
  requestedByUserId String
  errorMessage      String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User       @relation("AiJobRequestedBy", fields: [requestedByUserId], references: [id])
  outputs     AiOutput[]

  @@index([tenantId, projectId, status])
  @@map("ai_jobs")
}

model AiOutput {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  jobId     String
  title     String
  content   String
  createdAt DateTime @default(now())

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job      AiJob             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  versions AiOutputVersion[]

  @@index([tenantId, projectId])
  @@map("ai_outputs")
}

// ── M5: Operations, Finance, Team ──────────────────────────────────────────

model ProjectStage {
  id          String             @id @default(cuid())
  tenantId    String
  projectId   String
  name        String
  description String?
  status      ProjectStageStatus @default(pending)
  dueDate     DateTime?
  sortOrder   Int                @default(0)
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([tenantId, projectId, sortOrder])
  @@map("project_stages")
}

model Contract {
  id                 String         @id @default(cuid())
  tenantId           String
  leadId             String?        @unique
  projectId          String?
  contractNo         String
  title              String
  brideName          String?
  groomName          String?
  phone              String?
  weddingDate        DateTime?
  venue              String?
  serviceContent     String?
  companyName        String?
  companyAddress     String?
  signToken          String?        @unique
  signTokenExpiresAt DateTime?
  status             ContractStatus @default(pending_sign)
  signedAt           DateTime?
  signatureData      String?
  rejectedAt         DateTime?
  rejectReason       String?
  note               String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead    Lead?    @relation("LeadContract")
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([tenantId, contractNo])
  @@index([tenantId, projectId])
  @@map("contracts")
}

// ── M7: Archive, Storage, AI Polish ──────────────────────────────────────

model AssetRetentionPolicy {
  id               String   @id @default(cuid())
  tenantId         String
  projectId        String   @unique
  retentionDays    Int
  archiveAfterDays Int      @default(0)
  notifyBeforeDays Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("asset_retention_policies")
}

model RetentionReminder {
  id        String                  @id @default(cuid())
  tenantId  String
  projectId String
  assetId   String?
  title     String
  remindAt  DateTime
  status    RetentionReminderStatus @default(pending)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, remindAt])
  @@map("retention_reminders")
}

model ArchivePackage {
  id              String               @id @default(cuid())
  tenantId        String
  projectId       String
  type            ArchivePackageType
  title           String
  status          ArchivePackageStatus @default(queued)
  objectKey       String?
  sizeBytes       Int?
  expiresAt       DateTime?
  errorMessage    String?
  createdByUserId String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("ArchivePackageCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     ArchivePackageItem[]

  @@index([tenantId, projectId, status])
  @@map("archive_packages")
}

model ArchivePackageItem {
  id        String   @id @default(cuid())
  packageId String
  assetId   String
  createdAt DateTime @default(now())

  package ArchivePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  asset   Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([packageId, assetId])
  @@map("archive_package_items")
}

model AiOutputVersion {
  id        String   @id @default(cuid())
  outputId  String
  version   Int
  title     String
  content   String
  note      String?
  createdAt DateTime @default(now())

  output AiOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@unique([outputId, version])
  @@map("ai_output_versions")
}

// ── AI Workbench: Material Types, Generations, Usage ───────────────────────

model MaterialType {
  id          String   @id @default(cuid())
  name        String
  code        String
  icon        String?
  defaultSize Json?
  sizes       Json?
  isSystem    Boolean  @default(false)
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generations AiGeneration[]

  @@unique([tenantId, code])
  @@map("material_types")
}

model AiGeneration {
  id                 String             @id @default(cuid())
  tenantId           String
  userId             String
  conversationId     String?
  parentGenerationId String?
  projectId          String?
  materialTypeId     String
  type               AiGenerationType   @default(text2img)
  prompt             String
  aiPrompt           String
  style              String
  size               Json
  sourceImageUrl     String?
  resultImageUrl     String?
  resultImageUrls    Json?
  resultPsdUrl       String?
  status             AiGenerationStatus @default(pending)
  errorMessage       String?
  metadata           Json?
  isBookmarked       Boolean            @default(false)
  bookmarkedAt       DateTime?
  businessTags       Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User         @relation("AiGenerationsByUser", fields: [userId], references: [id])
  materialType MaterialType @relation(fields: [materialTypeId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  conversations          AiConversationMessage[]
  conversationCurrentGen AiConversation[]        @relation("ConversationCurrentGen")
  images                 AiGenerationImage[]
  jobs                   AiGenerationJob[]
  feedbacks              AiGenerationFeedback[]

  @@index([tenantId, status])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, isBookmarked, createdAt])
  @@index([tenantId, projectId, createdAt])
  @@index([parentGenerationId])
  @@index([userId, createdAt])
  @@map("ai_generations")
}

model AiGenerationImage {
  id           String   @id @default(cuid())
  generationId String
  tenantId     String
  url          String
  index        Int
  width        Int?
  height       Int?
  provider     String?
  model        String?
  seed         String?
  metadata     Json?
  isSelected   Boolean  @default(false)
  isBookmarked Boolean  @default(false)
  createdAt    DateTime @default(now())

  generation AiGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([generationId, index])
  @@index([tenantId, createdAt])
  @@map("ai_generation_images")
}

model AiGenerationJob {
  id           String                @id @default(cuid())
  generationId String
  tenantId     String
  status       AiGenerationJobStatus @default(queued)
  progress     Int                   @default(0)
  provider     String?
  model        String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime              @default(now())

  generation AiGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([generationId])
  @@index([tenantId, createdAt])
  @@map("ai_generation_jobs")
}

model AiConversation {
  id                  String   @id @default(cuid())
  tenantId            String
  userId              String
  projectId           String?
  title               String
  currentGenerationId String?
  currentDesignState  Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  currentGeneration AiGeneration?           @relation("ConversationCurrentGen", fields: [currentGenerationId], references: [id], onDelete: SetNull)
  messages          AiConversationMessage[]
  referenceAssets   AiReferenceAsset[]

  @@index([tenantId, projectId, updatedAt])
  @@map("ai_conversations")
}

model AiConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  tenantId       String
  role           MessageRole
  content        String?
  attachments    Json?
  generationId   String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  generation   AiGeneration?  @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([tenantId, conversationId, createdAt])
  @@map("ai_conversation_messages")
}

model AiUsageRecord {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@map("ai_usage_records")
}

model AiGenerationFeedback {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  generationId String
  imageId      String?
  rating       Int
  reason       String?
  createdAt    DateTime @default(now())

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation AiGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("ai_generation_feedback")
}

model AiReferenceAsset {
  id             String             @id @default(cuid())
  tenantId       String
  userId         String
  projectId      String?
  conversationId String?
  role           ReferenceAssetRole
  url            String
  thumbnailUrl   String?
  filename       String
  contentType    String
  sizeBytes      Int
  width          Int?
  height         Int?
  metadata       Json?
  createdAt      DateTime           @default(now())

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, conversationId, createdAt])
  @@map("ai_reference_assets")
}

// ── AI Text Generation ─────────────────────────────────────────────────────

model AiTextGeneration {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  projectId    String?
  type         String // vows, speech, social_copy, invitation, story
  prompt       String
  result       String
  style        String?
  language     String   @default("zh")
  metadata     Json?
  isBookmarked Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("ai_text_generations")
}

// ── M8: Platform settings ──────────────────────────────────────────────────

model PlatformSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  group        String
  label        String
  value        Json
  defaultValue Json?
  encrypted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([group])
  @@map("platform_settings")
}

model MaterialCategory {
  id        String   @id @default(cuid())
  tenantId  String?  // null = built-in (platform-managed)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials Material[]

  @@index([tenantId])
  @@map("material_categories")
}

model Material {
  id         String         @id @default(cuid())
  tenantId   String?        // null = built-in (platform-managed)
  categoryId String
  name       String
  status     MaterialStatus @default(missing)
  quantity   Int?
  note       String?
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  MaterialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  taskItems TaskMaterial[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("materials")
}

model QuickPromptCategory {
  id        String             @id @default(cuid())
  tenantId  String?
  name      String
  type      PromptCategoryType @default(general)
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenant Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prompts QuickPrompt[]

  @@index([tenantId])
  @@map("quick_prompt_categories")
}

model QuickPrompt {
  id         String   @id @default(cuid())
  tenantId   String?  // null = built-in (platform-managed)
  categoryId String
  name       String
  prompt     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category QuickPromptCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([categoryId])
  @@map("quick_prompts")
}

model TaskMaterial {
  id         String   @id @default(cuid())
  taskId     String
  materialId String
  confirmed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([taskId, materialId])
  @@map("task_materials")
}

model TaskAssignee {
  id       String @id @default(cuid())
  taskId   String
  memberId String

  task   Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
  @@map("task_assignees")
}

model Subtask {
  id          String   @id @default(cuid())
  taskId      String
  tenantId    String
  title       String
  isCompleted Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId, sortOrder])
  @@map("subtasks")
}
