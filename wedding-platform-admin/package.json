{
  "name": "wedding-platform-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "(cd ../wedding-platform-api && pnpm dev) & bun dev & wait",
    "stop": "lsof -ti:3000 | xargs kill -9 2>/dev/null; lsof -ti:4000 | xargs kill -9 2>/dev/null; echo 'Admin(:3000) + API(:4000) stopped'",
    "build": "next build",
    "start:prod": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && bun format",
    "lint:strict": "oxlint --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "dependencies": {
